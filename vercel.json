{
  "rewrites": [
    { "source": "/manifest.json", "destination": "/api/manifest" },
    { "source": "/catalog/:type/:id/:extra", "destination": "/api/catalog/:type/:id?extra=:extra" },
    { "source": "/catalog/:type/:id", "destination": "/api/catalog/:type/:id" },
    { "source": "/meta/:type/:id", "destination": "/api/meta/:type/:id" },
    { "source": "/stream/:type/:id", "destination": "/api/live/:type/:id" },
    { "source": "/guide/:id", "destination": "/api/guide/:id" },
    { "source": "/sports/manifest.json", "destination": "/api/sports/manifest" },
    { "source": "/sports/catalog/:type/:id", "destination": "/api/sports/catalog/:type/:id" },
    { "source": "/sports/meta/:type/:id", "destination": "/api/sports/meta/:type/:id" },
    { "source": "/sports/stream/:type/:id", "destination": "/api/sports/live/:type/:id" },
    { "source": "/sports/poster/:id", "destination": "/api/sports/poster/:id" }
  ],
  "functions": {
    "api/cron/refresh.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 6 * * *"
    }
  ]
}
